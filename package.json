{
  "name": "super-gol",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Digital recreation of Super Gol, the 90s Marca football card game — collect, build, compete.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "build:function": "esbuild supabase/functions/_src/play-match.ts --bundle --format=esm --platform=neutral --target=deno1 --tsconfig=tsconfig.app.json --external:npm:@supabase/supabase-js@2.47.10 --banner:js='// GENERATED by `npm run build:function` from supabase/functions/_src/play-match.ts — do not edit.' --outfile=supabase/functions/play-match/index.ts",
    "build:cards": "tsx scripts/cards/build.ts",
    "build:cards:all": "npm run build:cards && npm run export:cards:csv",
    "reseed:cards": "tsx scripts/cards/reseed.ts",
    "push:cards": "tsx scripts/cards/push.ts",
    "export:cards:csv": "tsx scripts/cards/export-csv.ts",
    "db:reset": "supabase db reset",
    "db:reset:linked": "supabase db reset --linked --no-seed",
    "db:push": "supabase db push"
  },
  "dependencies": {
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@heroicons/react": "^2.2.0",
    "@supabase/supabase-js": "^2.47.10",
    "papaparse": "^5.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.28.1",
    "postcss": "^8.4.49",
    "supabase": "^2.109.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.9"
  }
}

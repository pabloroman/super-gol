# Supabase — copy to .env and fill with your project's values.
# Find these in your Supabase dashboard: Project Settings → API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional dev flag: set to 1 to run the real match engine in the browser instead
# of calling the authoritative `play-match` Edge Function. Handy for previewing the
# rules without deploying the function — it awards NO real coins.
# VITE_LOCAL_ENGINE=1

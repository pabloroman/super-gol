# Supabase — copy to .env.local (or .env) and fill with your project's values.
# Find these in your Supabase dashboard: Project Settings → API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# New-style public key (the dashboard calls it the "publishable" key).
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
# The old VITE_SUPABASE_ANON_KEY name is still accepted as a fallback.
